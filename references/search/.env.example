# Shared LLM settings for keyword extraction, KG query understanding,
# PDF reference selection, and optional final reranking.
SEARCH_LLM_API_KEY=
SEARCH_LLM_API_URL=https://api.openai.com/v1/chat/completions
SEARCH_LLM_MODEL=gpt-4.1-mini

# Legacy key names are still accepted for compatibility:
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4.1-mini
# DMX-API-KEY=

# Semantic Scholar
S2-API-KEY=

# KG / Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Optional model overrides
INNOEVAL_SEARCH_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
INNOEVAL_SEARCH_RERANKER_MODEL=BAAI/bge-reranker-large
